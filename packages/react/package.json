{
  "name": "@sigsafe/react",
  "version": "0.1.0",
  "description": "React components for sigsafe — a drop-in <SignatureGuard> that decodes and risk-flags any EVM signature before the user signs.",
  "license": "MIT",
  "author": "Prazwal Ratti (https://github.com/PrazwalR)",
  "homepage": "https://github.com/PrazwalR/SigSafe/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrazwalR/SigSafe.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/PrazwalR/SigSafe/issues"
  },
  "keywords": [
    "react",
    "ethereum",
    "evm",
    "wallet",
    "security",
    "signature",
    "permit",
    "eip-712",
    "eip-7702",
    "signature-guard",
    "sigsafe"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sigsafe/core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1"
  }
}
